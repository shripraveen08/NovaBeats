<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme — Compose handles most theming -->
    <style name="Theme.Raga" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">#191414</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.Raga.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#191414</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.Raga</item>
    </style>
</resources>
